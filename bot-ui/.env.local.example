# DMZ bot socket API (used by Next.js API route proxy + Socket.IO)
BOT_SOCKET_URL=http://localhost:9001
# For access from other PCs, use your server LAN IP instead of localhost.
# Example: NEXT_PUBLIC_BOT_SOCKET_URL=http://192.168.1.50:9001
NEXT_PUBLIC_BOT_SOCKET_URL=http://localhost:9001

# MZ admin API for KB management proxy routes
ADMIN_API_URL=http://localhost:9002

# Admin KB access (server-side only — never exposed to browser bundle)
ADMIN_SECRET=
NEXT_PUBLIC_ADMIN_ENABLED=true
NEXT_PUBLIC_ADMIN_UI_URL=http://localhost:3002
