# ─── LLM Provider ───────────────────────────────────────────────────────────
# Ollama (default — requires Ollama running locally)
OLLAMA_BASE_URL=http://10.11.200.109:11434
MODEL_NAME=ollama/qwen3.5:4b
# Set to true to enable chain-of-thought / thinking tokens (Qwen3, etc.)
LLM_THINKING=false
# Optional: use a smaller/faster model for intent classification only.
# Highly recommended when using a large main model (e.g. qwen3.5:27b).
# Example: CLASSIFIER_MODEL=ollama/granite4.1:3b-q4_K_M
# CLASSIFIER_MODEL=ollama/granite4.1:3b-q4_K_M

# To switch to OpenAI: MODEL_NAME=gpt-4o  (also set OPENAI_API_KEY)
# To switch to Anthropic: MODEL_NAME=claude-3-5-sonnet-20241022  (set ANTHROPIC_API_KEY)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Agent Settings ─────────────────────────────────────────────────────────
MAX_ITERATIONS=10
DEFAULT_TEMPERATURE=0.3
CLASSIFIER_TIMEOUT_MS=14000

# ─── Memory ─────────────────────────────────────────────────────────────────
MEMORY_PERSIST_DIR=./memory_store

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=9001
CORS_ORIGINS=["http://localhost:3001","http://localhost:3002"]

# ─── Optional: Real web search ───────────────────────────────────────────────
# BRAVE_API_KEY=your_key

# ─── Identity / Session ─────────────────────────────────────────────────────
# Leave empty for dev/test mode (HMAC check skipped — any user_id accepted).
# Set to a 32+ char random string in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Optional Redis cache — omit to use PostgreSQL only.
# REDIS_URL=redis://10.11.200.99:6379/0
# SERPAPI_API_KEY=your_key

# ─── PostgreSQL + PgVector ───────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://banking_kb_admin:Era%401234@10.11.200.99:5432/banking_kb

# ─── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=snowflake-arctic-embed2:latest
EMBEDDING_DIMS=1024
EMBEDDING_ATTEMPTS=2
EMBEDDING_TIMEOUT_MS=800
EMBEDDING_BREAKER_FAILURE_THRESHOLD=2

# ─── KB Retrieval ───────────────────────────────────────────────────────────
# Number of chunks fetched during the parallel pre-fetch (broad queries need more).
KB_PREFETCH_TOP_K=6

# ─── Flow Settings ──────────────────────────────────────────────────────────
# Set to false to use static template responses at flow completion instead of KB-grounded LLM replies.
FLOW_KB_AUGMENT=true
EMBEDDING_BREAKER_COOLDOWN_SECONDS=60

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_SECRET=Era-KB-Admin-2026-S3cr3t

# ─── Banking branding ────────────────────────────────────────────────────────
BANK_NAME=Bank Asia

