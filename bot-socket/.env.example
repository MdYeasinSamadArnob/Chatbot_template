# ─── LLM Provider ───────────────────────────────────────────────────────────
# Ollama (default — requires Ollama running locally)
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=ollama/llama3.2

# Optional: use a smaller/faster model for intent classification only.
# Recommended for this project: CLASSIFIER_MODEL=ollama/granite4.1:3b-q4_K_M
CLASSIFIER_MODEL=

# To switch to OpenAI: MODEL_NAME=gpt-4o  (also set OPENAI_API_KEY)
# To switch to Anthropic: MODEL_NAME=claude-3-5-sonnet-20241022  (set ANTHROPIC_API_KEY)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Agent Settings ─────────────────────────────────────────────────────────
MAX_ITERATIONS=10
DEFAULT_TEMPERATURE=0.3

# Latency tuning (production)
CLASSIFIER_CACHE_TTL_SECONDS=180
CLASSIFIER_CACHE_MAX_ENTRIES=1024
CLASSIFIER_TIMEOUT_MS=4000
KB_PREFETCH_TIMEOUT_MS=1200
KB_PREFETCH_TIMEOUT_MS_DEGRADED=400
DISABLE_KB_TOOL_WHEN_EMBEDDING_DOWN=true
EMBEDDING_BREAKER_FAILURE_THRESHOLD=3
EMBEDDING_BREAKER_COOLDOWN_SECONDS=45
EMBEDDING_DIMS=1024
EMBEDDING_ATTEMPTS=1
EMBEDDING_TIMEOUT_MS=2200
EMBEDDING_CACHE_TTL_SECONDS=900
EMBEDDING_CACHE_MAX_ENTRIES=2048
VECTOR_HNSW_EF_SEARCH=96
VECTOR_CANDIDATE_MULTIPLIER=10
SPARSE_CANDIDATE_MULTIPLIER=6
HYBRID_DENSE_WEIGHT=0.75
HYBRID_SPARSE_WEIGHT=0.25
HYBRID_RRF_K=60
HYBRID_MIN_DENSE_SIMILARITY=0.20
HYBRID_LEXICAL_BOOST=0.12
HYBRID_MAX_CHUNKS_PER_DOCUMENT=2

# ─── Memory ─────────────────────────────────────────────────────────────────
MEMORY_PERSIST_DIR=./memory_store

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=9001
CORS_ORIGINS=["http://localhost:3001","http://localhost:3002"]

# ─── Optional: Real web search ───────────────────────────────────────────────
# BRAVE_API_KEY=your_key
# SERPAPI_API_KEY=your_key
