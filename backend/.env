# ─── LLM Provider ───────────────────────────────────────────────────────────
# Ollama (default — requires Ollama running locally)
OLLAMA_BASE_URL=http://10.11.200.109:11434
MODEL_NAME=ollama/llama3.2:3b

# To switch to OpenAI: MODEL_NAME=gpt-4o  (also set OPENAI_API_KEY)
# To switch to Anthropic: MODEL_NAME=claude-3-5-sonnet-20241022  (set ANTHROPIC_API_KEY)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Agent Settings ─────────────────────────────────────────────────────────
MAX_ITERATIONS=10
DEFAULT_TEMPERATURE=0.3

# ─── Memory ─────────────────────────────────────────────────────────────────
MEMORY_PERSIST_DIR=./memory_store

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ─── Optional: Real web search ───────────────────────────────────────────────
# BRAVE_API_KEY=your_key
# SERPAPI_API_KEY=your_key

# ─── PostgreSQL + PgVector ───────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:bankbot2024@localhost:5432/bankbot

# ─── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=snowflake-arctic-embed2:latest

# ─── Banking branding ────────────────────────────────────────────────────────
BANK_NAME=MyBank

